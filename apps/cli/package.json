{
  "name": "@bap/cli",
  "private": true,
  "version": "0.1.0",
  "type": "module",
  "bin": {
    "bap": "src/bin/bap.ts"
  },
  "scripts": {
    "dev": "bun --watch --env-file=../../.env src/bin/bap.ts",
    "start": "bun --env-file=../../.env src/bin/bap.ts",
    "build": "bunx tsc --noEmit -p tsconfig.json",
    "check": "bunx tsc --noEmit -p tsconfig.json",
    "test": "bun run test:unit",
    "test:unit": "vitest run"
  },
  "dependencies": {
    "@bap/client": "workspace:*",
    "@bap/core": "workspace:*",
    "@bap/db": "workspace:*",
    "@stricli/core": "^1.2.6",
    "drizzle-orm": "^0.45.1"
  },
  "devDependencies": {
    "@types/bun": "^1.3.6",
    "@types/node": "^20",
    "typescript": "^5",
    "vitest": "^4.0.18"
  }
}
