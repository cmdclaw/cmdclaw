{
  "name": "cmdclaw",
  "private": true,
  "packageManager": "bun@1.3.9",
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "scripts": {
    "cat": "bun scripts/cat.ts",
    "cli": "bun run --cwd apps/cli start",
    "cmdclaw": "bun run --cwd apps/cli start",
    "env": "infisical export --output-file=.env",
    "dev": "bun --env-file=.env turbo dev --filter=@cmdclaw/web --filter=@cmdclaw/worker --filter=@cmdclaw/ws --ui=tui",
    "dev:worktree": "bun scripts/worktree.ts dev",
    "dev:timed": "bash -lc 'set -o pipefail; FORCE_COLOR=1 CLICOLOR_FORCE=1 bun --env-file=.env turbo run dev --filter=@cmdclaw/web --filter=@cmdclaw/worker --filter=@cmdclaw/ws --ui=stream --log-prefix=task --log-order=stream --color 2>&1 | perl -ne '\\''BEGIN { $| = 1 } chomp; @t = localtime; printf(\"[%04d-%02d-%02d %02d:%02d:%02d] %s\\n\", $t[5] + 1900, $t[4] + 1, $t[3], $t[2], $t[1], $t[0], $_);'\\'''",
    "dev:selfhost": "bun --env-file=.env.selfhost turbo dev:selfhost --filter=@cmdclaw/web --filter=@cmdclaw/worker --filter=@cmdclaw/ws --ui=tui",
    "dev:selfhost:web": "bun --env-file=.env.selfhost turbo dev:selfhost --filter=@cmdclaw/web",
    "build": "turbo build",
    "check": "turbo check",
    "test": "bun run test:ci",
    "test:ui": "vitest --config vitest.ui.config.ts --ui --open",
    "dev:web": "bun --env-file=.env turbo dev --filter=@cmdclaw/web",
    "dev:docs": "turbo dev --filter=@cmdclaw/docs",
    "dev:worker": "bun --env-file=.env turbo dev --filter=@cmdclaw/worker",
    "dev:ws": "bun --env-file=.env turbo dev --filter=@cmdclaw/ws",
    "dev:mcp": "turbo dev --filter=@cmdclaw/mcp",
    "start:web": "bun --env-file=.env run --cwd apps/web start",
    "start:worker": "bun --env-file=.env run --cwd apps/worker start",
    "start:ws": "bun --env-file=.env run --cwd apps/ws start",
    "start:mcp": "bun run --cwd apps/mcp start",
    "build:web": "turbo build --filter=@cmdclaw/web",
    "build:cli": "turbo build --filter=@cmdclaw/cli",
    "build:docs": "turbo build --filter=@cmdclaw/docs",
    "build:mcp": "turbo build --filter=@cmdclaw/mcp",
    "build:worker": "turbo build --filter=@cmdclaw/worker",
    "build:ws": "turbo build --filter=@cmdclaw/ws",
    "db:push": "bun --env-file=.env run --cwd apps/web db:push",
    "workflow": "bun run --cwd apps/web workflow",
    "db:seed": "bun --env-file=.env run --cwd apps/web db:seed",
    "db:reset": "bun --env-file=.env run --cwd apps/web db:reset",
    "db:studio": "bun --env-file=.env run --cwd apps/web db:studio",
    "db:studio:prod": "bun --env-file=.env run --cwd apps/web db:studio:prod",
    "db:studio:staging": "bun --env-file=.env run --cwd apps/web db:studio:staging",
    "worktree": "bun scripts/worktree.ts",
    "worktree:create": "bun scripts/worktree.ts create",
    "worktree:setup": "bun scripts/worktree.ts setup",
    "worktree:stop": "bun scripts/worktree.ts stop",
    "worktree:destroy": "bun scripts/worktree.ts destroy",
    "worktree:status": "bun scripts/worktree.ts status",
    "worktree:env": "bun scripts/worktree.ts env",
    "worktree:docker-up": "bun scripts/worktree.ts docker-up",
    "worktree:docker-down": "bun scripts/worktree.ts docker-down",
    "worktree:bootstrap-user": "bun scripts/worktree.ts bootstrap-user",
    "check:cli": "turbo check --filter=@cmdclaw/cli",
    "cli:e2e:live:record": "bun run --cwd apps/web test:e2e:live:record",
    "check:web": "turbo check --filter=@cmdclaw/web",
    "check:docs": "turbo check --filter=@cmdclaw/docs",
    "check:mcp": "turbo check --filter=@cmdclaw/mcp",
    "check:worker": "turbo check --filter=@cmdclaw/worker",
    "check:ws": "turbo check --filter=@cmdclaw/ws",
    "test:all": "bun run test:ci && bun run test:live",
    "test:ci": "bun run test:unit && bun run test:integration && bun run test:e2e",
    "test:e2e": "turbo run test:e2e --filter=@cmdclaw/web",
    "test:integration": "turbo run test:integration --filter=@cmdclaw/web",
    "test:interactive": "turbo run test:interactive --filter=@cmdclaw/web",
    "test:live": "turbo run test:live --filter=@cmdclaw/web",
    "test:live:auth": "turbo run test:live:auth --filter=@cmdclaw/web",
    "test:live:cli": "turbo run test:live:cli --filter=@cmdclaw/web",
    "test:live:web": "turbo run test:live:web --filter=@cmdclaw/web",
    "test:monitor": "turbo run test:monitor --filter=@cmdclaw/web",
    "test:prod": "turbo run test:prod --filter=@cmdclaw/web",
    "test:record": "turbo run test:record --filter=@cmdclaw/web",
    "test:unit": "turbo run test:unit --filter=@cmdclaw/cli --filter=@cmdclaw/mcp --filter=@cmdclaw/client --filter=@cmdclaw/core --filter=@cmdclaw/web"
  },
  "devDependencies": {
    "@vitest/ui": "4.0.18",
    "turbo": "^2.8.16",
    "vitest": "^4.0.18"
  },
  "patchedDependencies": {
    "drizzle-kit@0.31.10": "patches/drizzle-kit@0.31.10.patch"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.29.0",
    "@opentelemetry/api": "^1.9.0",
    "@opentelemetry/context-async-hooks": "^2.2.0",
    "@opentelemetry/core": "^2.2.0",
    "@opentelemetry/exporter-metrics-otlp-proto": "^0.207.0",
    "@opentelemetry/exporter-trace-otlp-proto": "^0.207.0",
    "@opentelemetry/resources": "^2.2.0",
    "@opentelemetry/sdk-metrics": "^2.2.0",
    "@opentelemetry/sdk-trace-base": "^2.2.0",
    "@opentelemetry/sdk-trace-node": "^2.2.0",
    "@opentelemetry/semantic-conventions": "^1.37.0"
  }
}
