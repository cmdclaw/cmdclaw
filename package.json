{
  "name": "cmdclaw",
  "private": true,
  "packageManager": "bun@1.3.9",
  "workspaces": [
    "apps/*",
    "packages/*",
    "docs"
  ],
  "scripts": {
    "cat": "bun scripts/cat.ts",
    "cmdclaw": "bun run --cwd apps/cli start --",
    "dev": "turbo dev --filter=@cmdclaw/web --filter=@cmdclaw/worker --filter=@cmdclaw/ws --ui=tui",
    "dev:selfhost": "bun --env-file=apps/web/.env.selfhost turbo dev:selfhost --filter=@cmdclaw/web --filter=@cmdclaw/worker --filter=@cmdclaw/ws --ui=tui",
    "dev:selfhost:web": "bun --env-file=apps/web/.env.selfhost turbo dev:selfhost --filter=@cmdclaw/web",
    "build": "turbo build",
    "check": "turbo check",
    "test": "turbo test",
    "dev:web": "turbo dev --filter=@cmdclaw/web",
    "dev:desktop": "turbo dev --filter=@cmdclaw/desktop",
    "dev:docs": "turbo dev --filter=@cmdclaw/docs",
    "dev:worker": "turbo dev --filter=@cmdclaw/worker",
    "dev:ws": "turbo dev --filter=@cmdclaw/ws",
    "dev:mcp": "turbo dev --filter=@cmdclaw/mcp",
    "start:web": "bun run --cwd apps/web start",
    "start:worker": "bun run --cwd apps/worker start",
    "start:ws": "bun run --cwd apps/ws start",
    "start:mcp": "bun run --cwd apps/mcp start",
    "build:web": "turbo build --filter=@cmdclaw/web",
    "build:cli": "turbo build --filter=@cmdclaw/cli",
    "build:desktop": "turbo build --filter=@cmdclaw/desktop",
    "build:docs": "turbo build --filter=@cmdclaw/docs",
    "build:mcp": "turbo build --filter=@cmdclaw/mcp",
    "build:worker": "turbo build --filter=@cmdclaw/worker",
    "build:ws": "turbo build --filter=@cmdclaw/ws",
    "db:push": "bun run --cwd apps/web db:push",
    "workflow": "bun run --cwd apps/web workflow",
    "db:seed": "bun run --cwd apps/web db:seed",
    "db:reset": "bun run --cwd apps/web db:reset",
    "db:studio": "bun run --cwd apps/web db:studio",
    "db:studio:prod": "bun run --cwd apps/web db:studio:prod",
    "db:studio:staging": "bun run --cwd apps/web db:studio:staging",
    "check:cli": "turbo check --filter=@cmdclaw/cli",
    "check:web": "turbo check --filter=@cmdclaw/web",
    "check:docs": "turbo check --filter=@cmdclaw/docs",
    "check:mcp": "turbo check --filter=@cmdclaw/mcp",
    "check:worker": "turbo check --filter=@cmdclaw/worker",
    "check:ws": "turbo check --filter=@cmdclaw/ws"
  },
  "devDependencies": {
    "turbo": "^2.8.16"
  },
  "patchedDependencies": {
    "drizzle-kit@0.31.10": "patches/drizzle-kit@0.31.10.patch"
  }
}
