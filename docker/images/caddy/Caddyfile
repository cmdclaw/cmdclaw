{
	admin off

	tailscale {
		state_dir /var/lib/tailscale

		observability {
			auth_key {env.TAILSCALE_AUTHKEY}
			hostname cmdclaw-observability-caddy-staging
		}
	}
}

(cloudflare) {
	tls {
		dns cloudflare {env.CLOUDFLARE_API_TOKEN}
	}
}

:{$PORT} {
	respond "ok" 200
}

observability.cmdclaw.ai {
	bind tailscale/observability
	respond "CmdClaw observability stack at observability.cmdclaw.ai. Use grafana.observability.cmdclaw.ai, metrics.observability.cmdclaw.ai, logs.observability.cmdclaw.ai, or traces.observability.cmdclaw.ai." 200
	import cloudflare
}

https://cmdclaw-observability-caddy-staging.tail3b24d0.ts.net {
	bind tailscale/observability
	respond "CmdClaw observability stack at cmdclaw-observability-caddy-staging.tail3b24d0.ts.net. Use observability.cmdclaw.ai or the observability subdomains." 200
}

grafana.observability.cmdclaw.ai {
	bind tailscale/observability
	reverse_proxy http://{$CMDCLAW_GRAFANA_HOST}:3000
	import cloudflare
}

metrics.observability.cmdclaw.ai {
	bind tailscale/observability
	reverse_proxy http://{$CMDCLAW_VICTORIA_METRICS_HOST}:8428
	import cloudflare
}

logs.observability.cmdclaw.ai {
	bind tailscale/observability
	reverse_proxy http://{$CMDCLAW_VICTORIA_LOGS_HOST}:9428
	import cloudflare
}

traces.observability.cmdclaw.ai {
	bind tailscale/observability
	reverse_proxy http://{$CMDCLAW_VICTORIA_TRACES_HOST}:10428
	import cloudflare
}
