{
	admin off
}

(cloudflare) {
	tls {
		dns cloudflare {env.CLOUDFLARE_API_TOKEN}
	}
}

(grafana_proxy) {
	encode zstd gzip

	reverse_proxy http://{$CMDCLAW_GRAFANA_HOST}:3000 {
		header_up Host {$CMDCLAW_GRAFANA_DOMAIN}
		header_up X-Forwarded-Host {$CMDCLAW_GRAFANA_DOMAIN}
		header_up X-Forwarded-Proto https
	}
}

(victoria_metrics_proxy) {
	encode zstd gzip

	reverse_proxy http://{$CMDCLAW_VICTORIA_METRICS_HOST}:8428 {
		header_up Host {$CMDCLAW_VICTORIA_METRICS_DOMAIN}
		header_up X-Forwarded-Host {$CMDCLAW_VICTORIA_METRICS_DOMAIN}
		header_up X-Forwarded-Proto https
	}
}

(victoria_logs_proxy) {
	encode zstd gzip

	reverse_proxy http://{$CMDCLAW_VICTORIA_LOGS_HOST}:9428 {
		header_up Host {$CMDCLAW_VICTORIA_LOGS_DOMAIN}
		header_up X-Forwarded-Host {$CMDCLAW_VICTORIA_LOGS_DOMAIN}
		header_up X-Forwarded-Proto https
	}
}

(victoria_traces_proxy) {
	encode zstd gzip

	reverse_proxy http://{$CMDCLAW_VICTORIA_TRACES_HOST}:10428 {
		header_up Host {$CMDCLAW_VICTORIA_TRACES_DOMAIN}
		header_up X-Forwarded-Host {$CMDCLAW_VICTORIA_TRACES_DOMAIN}
		header_up X-Forwarded-Proto https
	}
}

:{$PORT:10000} {
	respond /health "ok" 200
	respond "not found" 404
}

{$CMDCLAW_GRAFANA_DOMAIN} {
	import cloudflare
	import grafana_proxy
}

{$CMDCLAW_VICTORIA_METRICS_DOMAIN} {
	import cloudflare
	import victoria_metrics_proxy
}

{$CMDCLAW_VICTORIA_LOGS_DOMAIN} {
	import cloudflare
	import victoria_logs_proxy
}

{$CMDCLAW_VICTORIA_TRACES_DOMAIN} {
	import cloudflare
	import victoria_traces_proxy
}
