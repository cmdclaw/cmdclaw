{
  "name": "@cmdclaw/db",
  "private": true,
  "version": "0.1.0",
  "type": "module",
  "exports": {
    ".": "./src/index.ts",
    "./auth-schema": "./src/auth-schema.ts",
    "./client": "./src/client.ts",
    "./schema": "./src/schema.ts"
  },
  "scripts": {
    "build": "bunx tsc --noEmit -p tsconfig.json",
    "check": "bunx tsc --noEmit -p tsconfig.json",
    "db:generate": "drizzle-kit generate --config=drizzle.config.ts",
    "db:migrate": "bun src/ensure-extensions.ts && drizzle-kit migrate --config=drizzle.config.ts",
    "db:push": "bun src/ensure-extensions.ts && drizzle-kit push --config=drizzle.config.ts",
    "db:studio": "drizzle-kit studio --config=drizzle.config.ts",
    "reset": "bun src/reset.ts",
    "seed": "bun src/seed.ts"
  },
  "dependencies": {
    "drizzle-orm": "^0.45.1",
    "pg": "^8.16.3",
    "zod": "^4.1.13"
  },
  "devDependencies": {
    "@types/pg": "^8.15.6",
    "drizzle-kit": "^0.31.10"
  }
}
